[workspace.package]
version = "1.0.0"
edition = "2024"
rust-version = "1.85"
authors = ["NexVigilant Team <team@nexvigilant.com>"]
description = "NexVigilant Core (nexcore) — The Vigilance Kernel for pharmacovigilance and intelligent automation"
license = "LicenseRef-Proprietary"
repository = "https://github.com/nexvigilant/nexcore"

[workspace.dependencies]
axum = { version = "0.8.0", features = ["macros"] }
tokio = { version = "1.38.0", features = ["full"] }
serde = { version = "1.0.204", features = ["derive"] }
serde_json = "1.0.120"
chrono = { version = "0.4.38", features = ["serde"] }
uuid = { version = "1.10.0", features = ["v4", "serde"] }
anyhow = "1.0.86"
tracing = "0.1.40"
tracing-subscriber = { version = "0.3.18", features = ["env-filter"] }
tower-http = { version = "0.5.2", features = ["cors", "trace", "compression-full"] }
utoipa = { version = "5.3", features = ["axum_extras", "chrono", "uuid"] }
reqwest = { version = "0.12.5", features = ["json"] }
futures = "0.3.30"
regex = "1.10.5"
dashmap = "6.0.1"
tempfile = "3.10.1"
thiserror = "1.0.61"
rusqlite = { version = "0.32", features = ["bundled", "serde_json"] }
clap = { version = "4.5.11", features = ["derive", "cargo", "env"] }
async-trait = "0.1.81"
dirs = "5.0.1"
base64 = "0.22.1"
walkdir = "2.5.0"
glob = "0.3.1"
toml = "0.8.15"
rayon = "1.10.0"
sha2 = "0.10.8"
hex = "0.4.3"
once_cell = "1.19.0"
flate2 = "1.0.30"
tar = "0.4.41"
url = "2.5.2"
urlencoding = "2.1.3"
phf = { version = "0.11.2", features = ["macros"] }
bytes = "1.6.1"
http-body-util = "0.1.2"
serde_yaml = "0.9.34"
toml_edit = "0.22.16"
csv = "1.3.0"
tokio-stream = "0.1.15"
