[workspace]

[package]
name = "nexcore-skill-exec"
version = "1.0.0"
edition = "2024"
authors = ["NexVigilant Team <team@nexvigilant.com>"]
license = "LicenseRef-Proprietary"
description = "Skill Execution Engine - Real execution of Claude Code skills via shell, binary, or library invocation"
keywords = ["skills", "execution", "orchestration", "automation"]
categories = ["command-line-utilities"]

[dependencies]
nexcore-lex-primitiva = { version = "0.1.0", path = "../nexcore-lex-primitiva", registry = "nexcore" }
serde = { version = "1.0.204", features = ["derive"] }
serde_json = { version = "1.0.120" }
tokio = { version = "1.38.0", features = ["full"] }
thiserror = { version = "1.0.61" }
tracing = { version = "0.1.40" }

# Async trait support
async-trait = "0.1"

# JSON Schema validation
jsonschema = "0.29"
dirs = { version = "5.0.1" }

[dev-dependencies]
tempfile = { version = "3.10.1" }
tokio-test = "0.4"

[lints.rust]
async_fn_in_trait = "allow"
dead_code = "allow"
unused_imports = "allow"
unused_variables = "allow"
unused_mut = "allow"
unused_assignments = "allow"
unused_must_use = "allow"

[lints.clippy]
all = "allow"
pedantic = "allow"
nursery = "allow"
cargo = "allow"
map_unwrap_or = "allow"
manual_map = "allow"
option_map_or_none = "allow"
derivable_impls = "allow"
unwrap_used = "allow"
expect_used = "allow"
panic = "allow"
todo = "allow"
unimplemented = "allow"
unreachable = "allow"
