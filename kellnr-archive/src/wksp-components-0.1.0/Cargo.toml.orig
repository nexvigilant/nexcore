[package]
name = "wksp-components"
version = "0.1.0"
edition = "2024"
description = "Ferrostack reusable Leptos components — Card, Input, Modal for NexVigilant apps"
publish = ["nexcore"]

[dependencies]
leptos = { workspace = true }
leptos_router = { workspace = true }
leptos_meta = { workspace = true }
serde = { workspace = true }
wksp-core = { workspace = true }
wksp-api-client = { workspace = true }

[features]
ssr = ["leptos/ssr", "leptos_router/ssr", "leptos_meta/ssr", "wksp-api-client/ssr"]
hydrate = ["leptos/hydrate", "wksp-api-client/hydrate"]
