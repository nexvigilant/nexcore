-- Hidden assumptions (surfaced by audit, now explicit)

axiom assume_dag_parents :
  "from-DAG parent choices inherited from nexcore-lex-primitiva",
  "325 tests prove acyclicity and reachability",
  "tests do NOT prove parent choices are the ONLY valid ones",
  "e.g. × from [∃, ς] — arguable, not proven necessary",
