// Prima Capability Multiplier — FULL SEND Demo
// Shows: How domain transfer MULTIPLIES capabilities

ωn("═══════════════════════════════════════════════════════════════")
ωn("     PRIMA CAPABILITY MULTIPLIER — FULL SEND EDITION")
ωn("═══════════════════════════════════════════════════════════════")
ωn("")

// ═══════════════════════════════════════════════════════════════════════════
// CAPABILITY MULTIPLICATION FUNCTION
// Uses >= for comparison (κ> for strict greater-than)
// ═══════════════════════════════════════════════════════════════════════════

μ multiply_capability(source_mastery: N, transfer: N, target_base: N) → N {
    λ transferred = source_mastery * transfer
    ∂ transfer >= 0.7 {
        target_base + (transferred * 1.5)
    } {
        target_base + transferred
    }
}

μ classify_transfer(t: N) → String {
    ∂ t >= 0.9 {
        "T1 (Universal)"
    } ∂ t >= 0.7 {
        "T2-P (Multiplier)"
    } ∂ t >= 0.5 {
        "T2-C (Transfer)"
    } {
        "T3 (Domain)"
    }
}

// ═══════════════════════════════════════════════════════════════════════════
// DOMAIN AFFINITIES
// ═══════════════════════════════════════════════════════════════════════════

ωn("DOMAIN AFFINITIES (T >= 0.7 = Multiplication Zone)")
ωn("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")

λ math_physics = 0.90
λ math_cs = 0.85
λ math_stats = 0.95
λ chem_pharma = 0.82
λ pharma_tox = 0.92
λ nursing_med = 0.65

ωn("  math→physics:  ", math_physics, " ", classify_transfer(math_physics))
ωn("  math→cs:       ", math_cs, " ", classify_transfer(math_cs))
ωn("  math→stats:    ", math_stats, " ", classify_transfer(math_stats))
ωn("  chem→pharma:   ", chem_pharma, " ", classify_transfer(chem_pharma))
ωn("  pharma→tox:    ", pharma_tox, " ", classify_transfer(pharma_tox))
ωn("  nursing→med:   ", nursing_med, " ", classify_transfer(nursing_med))
ωn("")

// ═══════════════════════════════════════════════════════════════════════════
// PHARMD CAPABILITY MULTIPLICATION
// ═══════════════════════════════════════════════════════════════════════════

ωn("EXAMPLE: PharmD → Signal Detection")
ωn("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")
ωn("")

λ pharmd_chem = 0.90
λ pharmd_pharm = 0.95
λ pharmd_stats = 0.80

λ transfer_chem = 0.75
λ transfer_pharm = 0.88
λ transfer_stats = 0.85

λ signal_base = 0.20

λ from_chem = multiply_capability(pharmd_chem, transfer_chem, 0.0)
λ from_pharm = multiply_capability(pharmd_pharm, transfer_pharm, 0.0)
λ from_stats = multiply_capability(pharmd_stats, transfer_stats, 0.0)

ωn("  Chemistry (", pharmd_chem, ") × transfer (", transfer_chem, "):")
ωn("    → ", from_chem)
ωn("")
ωn("  Pharmacology (", pharmd_pharm, ") × transfer (", transfer_pharm, "):")
ωn("    → ", from_pharm)
ωn("")
ωn("  Statistics (", pharmd_stats, ") × transfer (", transfer_stats, "):")
ωn("    → ", from_stats)
ωn("")

λ total = signal_base + from_chem + from_pharm + from_stats
ωn("  TOTAL SIGNAL DETECTION CAPABILITY:")
ωn("    Base: ", signal_base)
ωn("    + Chemistry:    ", from_chem)
ωn("    + Pharmacology: ", from_pharm)
ωn("    + Statistics:   ", from_stats)
ωn("    ────────────────────────")
ωn("    = ", total)
ωn("")

