// ═══════════════════════════════════════════════════════════════════════════
// PIPELINE MULTIPLICATION
// ═══════════════════════════════════════════════════════════════════════════

ωn("CAPABILITY PIPELINE")
ωn("━━━━━━━━━━━━━━━━━━━")

λ pipeline = 5.0
    |> |x| x * 2.0
    |> |x| x * 3.0
    |> |x| x * 4.0

ωn("  5.0 × 2.0 × 3.0 × 4.0 = ", pipeline)
ωn("")

// ═══════════════════════════════════════════════════════════════════════════
// MULTIPLY vs ADD
// ═══════════════════════════════════════════════════════════════════════════

ωn("MULTIPLICATION vs ADDITION")
ωn("━━━━━━━━━━━━━━━━━━━━━━━━━━")

λ a = 0.8
λ b = 0.7
λ c = 0.9

λ added = a + b + c
λ multiplied = a * b * c * 10.0

ωn("  Skills: ", a, ", ", b, ", ", c)
ωn("  ADDED:      ", added)
ωn("  MULTIPLIED: ", multiplied)
ωn("  → Multiplication = COMPOUND growth!")
ωn("")

