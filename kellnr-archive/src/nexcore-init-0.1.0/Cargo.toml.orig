[workspace]

[package]
name = "nexcore-init"
version = "0.1.0"
edition = "2024"
rust-version = "1.85"
description = "NexCore Init — PID 1 init process for NexCore OS"
authors = ["Matthew Campion, PharmD <matthew@nexvigilant.com>"]
license = "LicenseRef-NexVigilant-Proprietary"
repository = "https://github.com/nexvigilant/nexcore"
keywords = ["init", "os", "boot", "pid1"]
categories = ["os"]

[[bin]]
name = "nexcore-init"
path = "src/main.rs"

[dependencies]
nexcore-pal = { version = "0.1.0", path = "../nexcore-pal", registry = "nexcore" }
nexcore-pal-linux = { version = "0.1.0", path = "../nexcore-pal-linux", registry = "nexcore" }
nexcore-os = { version = "0.1.0", path = "../nexcore-os", registry = "nexcore" }
nexcore-compositor = { version = "0.1.0", path = "../nexcore-compositor", registry = "nexcore" }
nexcore-shell = { version = "0.1.0", path = "../nexcore-shell", registry = "nexcore" }
nexcore-lex-primitiva = { version = "0.1.0", path = "../nexcore-lex-primitiva", registry = "nexcore" }
tracing = { version = "0.1.40" }
tracing-subscriber = { version = "0.3", features = ["env-filter", "fmt"] }

[lints.rust]
unsafe_code = "forbid"

[lints.clippy]
all = "warn"
pedantic = "warn"
nursery = "warn"
unwrap_used = "deny"
expect_used = "deny"
panic = "deny"
missing_errors_doc = "allow"
missing_panics_doc = "allow"
must_use_candidate = "allow"
module_name_repetitions = "allow"
doc_markdown = "allow"
missing_const_for_fn = "allow"
cast_possible_truncation = "allow"
option_if_let_else = "allow"
significant_drop_tightening = "allow"
