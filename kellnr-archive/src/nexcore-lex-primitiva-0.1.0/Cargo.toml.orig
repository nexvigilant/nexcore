[workspace]

[package]
name = "nexcore-lex-primitiva"
version = "0.1.0"
edition = "2024"
rust-version = "1.85"
description = "The 16 irreducible Lex Primitiva symbols with mathematical constants grounding"
license = "MIT"
repository = "https://github.com/nexvigilant/nexcore"
keywords = ["primitives", "type-theory", "grounding", "mathematics"]
categories = ["data-structures", "mathematics"]

[lib]
path = "src/lib.rs"

[[bin]]
name = "lex-primitiva"
path = "src/bin/main.rs"

[dependencies]
serde = { version = "1.0.204", features = ["derive"] }
serde_json = { version = "1.0.120" }
clap = { version = "4.5.11", features = ["derive", "cargo", "env"] }

[dev-dependencies]
# stem-math temporarily removed for initial publish (circular dev-dep)
proptest = { version = "1.6.0" }

[lints.rust]
async_fn_in_trait = "allow"
dead_code = "allow"
unused_imports = "allow"
unused_variables = "allow"
unused_mut = "allow"
unused_assignments = "allow"
unused_must_use = "allow"

[lints.clippy]
all = "allow"
pedantic = "allow"
nursery = "allow"
cargo = "allow"
map_unwrap_or = "allow"
manual_map = "allow"
option_map_or_none = "allow"
derivable_impls = "allow"
unwrap_used = "allow"
expect_used = "allow"
panic = "allow"
todo = "allow"
unimplemented = "allow"
unreachable = "allow"
