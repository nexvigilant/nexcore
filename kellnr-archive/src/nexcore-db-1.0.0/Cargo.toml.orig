[workspace]

[package]
name = "nexcore-db"
version = "1.0.0"
edition = "2024"
rust-version = "1.85"
description = "Persistent SQLite storage for NexCore Brain working memory"
license = "LicenseRef-Proprietary"

[dependencies]
rusqlite = { version = "0.32", features = ["bundled", "serde_json"] }
serde = { version = "1.0.204", features = ["derive"] }
serde_json = { version = "1.0.120" }
chrono = { version = "0.4.38", features = ["serde"] }
tracing = { version = "0.1.40" }
thiserror = { version = "1.0.61" }

[[bin]]
name = "brain-migrate"
path = "src/bin/migrate.rs"

[[bin]]
name = "brain-db-insert"
path = "src/bin/insert_decision.rs"

[lints.rust]
async_fn_in_trait = "allow"
dead_code = "allow"
unused_imports = "allow"
unused_variables = "allow"
unused_mut = "allow"
unused_assignments = "allow"
unused_must_use = "allow"

[lints.clippy]
all = "allow"
pedantic = "allow"
nursery = "allow"
cargo = "allow"
map_unwrap_or = "allow"
manual_map = "allow"
option_map_or_none = "allow"
derivable_impls = "allow"
unwrap_used = "allow"
expect_used = "allow"
panic = "allow"
todo = "allow"
unimplemented = "allow"
unreachable = "allow"
