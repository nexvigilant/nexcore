# Build artifacts
target/
**/target/

# Git
.git/

# IDE
.idea/
.vscode/
*.swp

# Crate directories must NOT be excluded — cargo metadata needs them for workspace resolution
# Even if a crate isn't compiled, its Cargo.toml must be parseable

# Claude state
.claude/

# Data files
*.db
*.sqlite
*.parquet
*.profraw
*.profdata

# Non-Rust directories (not needed for API build)
archive/
archived/
studio/
data/
dna/
ksb/
kellnr/
kellnr-archive/
docs/
notebooks/
prototypes/
scripts/
# tools/ MUST stay — dag-publish is a workspace dep of nexcore-mcp
.build-orchestrator/
wksp/
nexcore-os-image/
content/
ferro-forge/
boot/
clippy_output.json

# Large ML crate (734MB) — stubbed in Dockerfile
crates/bert-burn/

# Re-include crate subdirs falsely matched by above patterns
!crates/**/ksb/
!crates/**/data/
!crates/**/docs/

# Secrets
.env
.env.local
*.pem
*.key
