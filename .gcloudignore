# Exclude build artifacts (largest)
target/
**/target/

# Exclude large crates not needed for API build (but keep their dirs for workspace resolution)
# Only exclude crates with large non-Rust assets that bloat the upload
crates/bert-burn/

# Exclude git
.git/

# Exclude IDE files
.idea/
.vscode/
*.swp


# Exclude large data files
*.db
*.sqlite
*.parquet

# Exclude non-Rust top-level directories (anchored with / to avoid matching crate subdirs)
/archive/
/studio/
/data/
/dna/
/ksb/
/kellnr/
/kellnr-archive/
/docs/
/notebooks/
/prototypes/
/scripts/
/.build-orchestrator/
/wksp/
/nexcore-os-image/
/content/
/ferro-forge/
/boot/
clippy_output.json

# Exclude Claude state files (large)
.claude/brain/
.claude/projects/
.claude/implicit/
.claude/metrics/
.claude/decision-audit/
.claude/verified/
.claude/plugins/

# Exclude env files
.env
.env.local
*.pem
*.key

# Exclude profiling data
*.profraw
*.profdata
