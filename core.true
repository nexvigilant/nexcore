-- .true — statements that answer to mathematics
-- v7.5 | 2026-02-09 | Matthew Campion, PharmD; NexVigilant
--
-- SYNTAX: 4 constructs. Nothing else exists.
--
--   axiom   SUBJECT : PROPERTIES              given, irreducible
--   def     SUBJECT : PROPERTIES              derived from axioms/defs
--   theorem SUBJECT : EXPRESSION   [PROOF]    proven from defs
--   ∎                                         nothing more to prove
--
-- RELATIONS:
--   ->  directed edge (A precedes B)
--   <>  inverse pair (A undoes B)
--   :   has property
--   =   equals
--
-- BOOLEAN VALUES:
--   every primitive has val=N where N is its Boolean function
--   of 2 variables (truth table read as 4-bit integer, 0-15)
--   6 are IDENTITY (the primitive IS the function): ∅,×,κ,Σ,→,∃
--   10 are MAPPING (argued, not self-evident): confidence varies per primitive
--
-- CONFIDENCE:
--   axiom    conf = 1.0               (given)
--   def      conf = min(parent confs) (conservative — see assume_min_propagation)
--   theorem  conf = proof_type:
--     computational  0.99   (code ran, tests passed)
--     analytical     0.95   (logic/math derivation)
--     mapping        0.90   (theory correspondence)
--     adversarial    0.85   (survived attacks)
--     empirical      0.80   (measurement matches prediction)
--   ∎        conf = min(all theorems)  (weakest link)
--
-- Comments: -- (to end of line)


-- ═══════════════════════════════════════════
-- AXIOMS — irreducible. accepted. not derived.
-- ═══════════════════════════════════════════

-- Constants

axiom ZERO : constant, "absence, additive identity, multiplicative annihilator"
axiom ONE  : constant, "existence, unit, witness"

-- Physics roots

axiom N  : prim, "Quantity",  root, symbol=N, val=9, bool=XNOR, val_conf=0.82, constant=ONE,
  physics="h(Planck) quantizes action; XNOR=equivalence=measurement; 50+ NIST mass ratios are equivalence tests"
axiom -> : prim, "Causality", root, symbol=→, val=13, bool=IMPLICATION, constant=e

-- Duality

axiom duality :
  "physics (N, ->) and semantics (SYMBOL) are dual views",
  "axioms ground in physics — electrons, voltage, clock",
  "execution operates on symbols — meaning, confidence, relations",
  "same 16 primitives, two derivation orders, one system",
  status=interpretive, "philosophical position, not mathematical proof",
  "both derivation orders produce same 16 — observed, not proven necessary"


-- ═══════════════════════════════════════════
-- DEFINITIONS — derived from axioms
-- ═══════════════════════════════════════════

-- 14 derived primitives (ordered by Boolean function value)
-- the 6 IDENTITIES are marked — these are not mappings, they ARE the function

def ∅  : prim, "Void",            from [∃, κ],     val=0,  bool=FALSE,          IDENTITY, constant=ZERO
def ×  : prim, "Product",         from [∃, ς],     val=1,  bool=AND,            IDENTITY, constant=ONE
def ∝  : prim, "Irreversibility", from [->, ∂, ς], val=2,  bool=INHIBIT,        constant=ln2
def ς  : prim, "State",           from [∃, λ],     val=3,  bool=LEFT_PROJ,      constant=i
def ∂  : prim, "Boundary",        from [κ, N],     val=4,  bool=CONV_INHIBIT,   constant=∞
def μ  : prim, "Mapping",         from [∃, ->],    val=5,  bool=RIGHT_PROJ,     constant=Ω
def κ  : prim, "Comparison",      from [N],        val=6,  bool=XOR,            IDENTITY, constant=√2
def Σ  : prim, "Sum",             from [κ, ∅],     val=7,  bool=OR,             IDENTITY, constant=γ
def ν  : prim, "Frequency",       from [σ, N, ∂],  val=8,  bool=NOR,            constant=π
def λ  : prim, "Location",        from [∃, N],     val=10, bool=NOT_B,          constant=ZERO,
  physics="Bohr radius a₀, Planck length, charge radii — position tracks object (A), not context (B)"
def ρ  : prim, "Recursion",       from [ς, μ, σ],  val=11, bool=CONV_IMPLY,     constant=φ
def π  : prim, "Persistence",     from [∃, ς, σ],  val=12, bool=NOT_A,          constant=∞,
  physics="fine-structure α=1/137, Rydberg, Stefan-Boltzmann — persists via substrate (B), not event (A)"
def σ  : prim, "Sequence",        from [ς, μ, ->], val=14, bool=NAND,           constant=ONE
def ∃  : prim, "Existence",       from [->],       val=15, bool=TRUE,           IDENTITY, constant=ONE
-- N = val 9  (axiom, XNOR)
-- -> = val 13 (axiom, IMPLICATION, IDENTITY)

-- Boolean algebra structure

def atoms : basis,
  "4 bit-position primitives generate all 16 by additive composition",
  atom_0 = ×,   -- bit 0, val=1,  AND
  atom_1 = ∝,   -- bit 1, val=2,  INHIBIT
  atom_2 = ∂,   -- bit 2, val=4,  CONV_INHIBIT
  atom_3 = ν    -- bit 3, val=8,  NOR

def halves : partition,
  "bit 1 splits 16 primitives into process and structure",
  process   = [∝, ς, κ, Σ, λ, ρ, σ, ∃], -- bit 1 set, core=∝, "doing"
  structure = [∅, ×, ∂, μ, ν, N, π, ->]  -- bit 1 clr, core=∅, "being"

def pascal : distribution,
  "popcount of val → primitive count = Pascal's row 4",
  depth_0 = [∅],                   -- 1 prim,  popcount=0
  depth_1 = [×, ∝, ∂, ν],         -- 4 prims, popcount=1
  depth_2 = [ς, μ, κ, N, λ, π],   -- 6 prims, popcount=2
  depth_3 = [Σ, ρ, ->, σ],        -- 4 prims, popcount=3
  depth_4 = [∃]                    -- 1 prim,  popcount=4

-- Tiers

def Pillar   : tier, [σ, κ, ς, ρ],  "structural foundations, highest transfer"
def Infra    : tier, [∂, μ, ∅, ->, ∃], "operational fabric, detectable in structure"
def Extended : tier, [π, ν, λ, ∝, Σ, ×], "semantic intent, only in meaning"

-- Layers

def Content  : layer, "single-episode knowledge transformation"
def Meta     : layer, "learning about learning"
def Temporal : layer, "across sessions"
def Guardian : layer, "error prevention"

-- Mechanisms (13 total, each maps to exactly 1 primitive, no repeats)

def DECOMPOSE : mech, prim=⊖, layer=Content,  var=D,  "break domain into atoms"
def SEQUENCE  : mech, prim=σ, layer=Content,  var=S,  "order by transfer confidence"
def ANCHOR    : mech, prim=∂, layer=Content,  var=A,  "find boundary of known/unknown"
def GROUND    : mech, prim=μ, layer=Content,  var=G,  "map new to known"
def CONTRAST  : mech, prim=κ, layer=Content,  var=K,  "show what it is not"
def VERIFY    : mech, prim=∃, layer=Content,  var=V,  "test if understanding exists"
def COMPRESS  : mech, prim=Σ, layer=Content,  var=Z,  "assign symbol, grow codebook"
def REFLECT   : mech, prim=ρ, layer=Meta,     var=M,  "what do I not know?"
def INTEGRATE : mech, prim=⊕, layer=Meta,     var=I,  "reassemble pieces into whole"
def TRANSFER  : mech, prim=λ, layer=Meta,     var=T,  "apply in novel context"
def SPACE     : mech, prim=ν, layer=Temporal, var=Sp, "distribute across time"
def CALIBRATE : mech, prim=N, layer=Temporal, var=C,  "adapt to learner level"
def PROTECT   : mech, prim=∂g,layer=Guardian, var=P,  "block misconceptions"

-- Execution DAG

def pipeline : dag,
  DECOMPOSE -> SEQUENCE,
  DECOMPOSE -> CONTRAST,
  SEQUENCE  -> ANCHOR,
  ANCHOR    -> GROUND,
  GROUND    -> VERIFY,
  CONTRAST  -> VERIFY,
  VERIFY    -> COMPRESS,
  COMPRESS  -> REFLECT,
  COMPRESS  -> INTEGRATE,
  COMPRESS  -> SPACE,
  INTEGRATE -> TRANSFER,
  ANCHOR    -> CALIBRATE,
  VERIFY    -> CALIBRATE

-- Dual pairs (inverse operations, additive in formula)

def analysis_synthesis : dual, DECOMPOSE <> INTEGRATE
def binding_unbinding  : dual, GROUND    <> TRANSFER

-- Floors (empirical minimums)

def floor_Sp : floor, var=Sp, base=0.30, weight=0.70, "Ebbinghaus 1885"
def floor_M  : floor, var=M,  base=0.10, weight=0.90, "children learn w/o metacognition"
def floor_P  : floor, var=P,  base=0.05, weight=0.95, "some learning despite misconceptions"
def floor_S  : floor, var=S,  base=0.20, weight=0.80, "random order still teaches"
def floor_A  : floor, var=A,  base=0.10, weight=0.90, "wrong anchor still starts"
def floor_V  : floor, var=V,  base=0.10, weight=0.90, "some learning w/o testing"
def floor_K  : floor, var=K,  base=0.15, weight=0.85, "partial understanding w/o contrast"
def floor_C  : floor, var=C,  base=0.20, weight=0.80, "uncalibrated still permits learning"
-- D, I, G, T, Z have no floor: dual pairs and compression correctly zero.

-- Execution model

def ASSERT  : op, construct=axiom,   "declare truth, conf=1.0"
def DERIVE  : op, construct=def,     "new symbol from parents, conf=min(parent confs)"
def PROVE   : op, construct=theorem, "validate relationship, conf=proof_type"
def HALT    : op, construct=∎,       "system conf = min(all theorem confs)"

def validation : passes,
  pass_1 = "syntax well-formed",
  pass_2 = "no duplicate subjects",
  pass_3 = "all from-refs exist",
  pass_4 = "DAG acyclic (topological sort succeeds)",
  pass_5 = "all theorems have [proof]",
  pass_6 = "file ends with ∎",
  pass_7 = "conf(child) <= min(conf(parents))",
  pass_8 = "spec ↔ impl cross-validate (val, from-refs, names vs nexcore-lex-primitiva)"


