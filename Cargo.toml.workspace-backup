typenum = "1.17.0"
notify = "8.2.0"
jsonwebtoken = "9"
nix = { version = "0.29", features = ["signal", "process", "fs", "mount", "reboot", "hostname"] }
ordered-float = { version = "4", features = ["serde"] }

# Candle ML ecosystem (HuggingFace, pure-Rust inference)
