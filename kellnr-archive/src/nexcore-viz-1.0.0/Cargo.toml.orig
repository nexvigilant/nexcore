[workspace]

[package]
name = "nexcore-viz"
version = "1.0.0"
edition = "2024"
rust-version = "1.85"
description = "STEM visualization engine — SVG diagrams for taxonomy, type composition, confidence propagation, and DAG topology"
license = "LicenseRef-Proprietary"

[dependencies]

[lints.rust]
async_fn_in_trait = "allow"
dead_code = "allow"
unused_imports = "allow"
unused_variables = "allow"
unused_mut = "allow"
unused_assignments = "allow"
unused_must_use = "allow"

[lints.clippy]
all = "allow"
pedantic = "allow"
nursery = "allow"
cargo = "allow"
map_unwrap_or = "allow"
manual_map = "allow"
option_map_or_none = "allow"
derivable_impls = "allow"
unwrap_used = "allow"
expect_used = "allow"
panic = "allow"
todo = "allow"
unimplemented = "allow"
unreachable = "allow"
