[workspace]

[package]
name = "prima-mcp-server"
version = "0.1.0"
edition = "2024"
rust-version = "1.85"
license = "LicenseRef-Proprietary"
authors = ["NexVigilant Team <team@nexvigilant.com>"]
description = "MCP server that executes Prima functions as tools"

[[bin]]
name = "prima-mcp-server"
path = "src/main.rs"

[dependencies]
prima = { version = "0.1.0", path = "../prima", registry = "nexcore" }
prima-mcp = { version = "0.1.0", path = "../prima-mcp", registry = "nexcore" }
prima-codegen = { version = "0.1.0", path = "../prima-codegen", registry = "nexcore" }
lex-primitiva = { version = "0.1.0", path = "../nexcore-lex-primitiva", registry = "nexcore", package = "nexcore-lex-primitiva" }
serde = { version = "1.0.204", features = ["derive"] }
serde_json = { version = "1.0.120" }
thiserror = { version = "1.0.61" }
tokio = { version = "1.38.0", features = ["full"] }

[dev-dependencies]
proptest = { version = "1.6.0" }

[lints.rust]
async_fn_in_trait = "allow"
dead_code = "allow"
unused_imports = "allow"
unused_variables = "allow"
unused_mut = "allow"
unused_assignments = "allow"
unused_must_use = "allow"

[lints.clippy]
all = "allow"
pedantic = "allow"
nursery = "allow"
cargo = "allow"
map_unwrap_or = "allow"
manual_map = "allow"
option_map_or_none = "allow"
derivable_impls = "allow"
unwrap_used = "allow"
expect_used = "allow"
panic = "allow"
todo = "allow"
unimplemented = "allow"
unreachable = "allow"
