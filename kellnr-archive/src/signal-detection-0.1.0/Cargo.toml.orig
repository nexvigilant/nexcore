[package]
name = "signal-detection"
version = "0.1.0"
edition = "2024"
description = "Pharmacovigilance signal detection using PRR algorithm"
authors = ["NexVigilant"]
license = "MIT"
publish = ["nexcore"]

[dependencies]
tokio = { version = "1.47", features = ["full"] }
anyhow = "1.0"
thiserror = "2.0"
tracing = "0.1"
tracing-subscriber = { version = "0.3", features = ["env-filter", "json"] }
clap = { version = "4.5", features = ["derive"] }
serde = { version = "1.0", features = ["derive"] }
serde_json = "1.0"
polars = { version = "0.46", features = ["lazy", "json", "parquet"] }
arrow = "54.0"
parquet = "54.0"
aws-sdk-s3 = "1.68"
aws-config = "1.5"
sqlx = { version = "0.8", features = ["runtime-tokio", "postgres", "mysql", "sqlite"] }
qdrant-client = "1.13"
chrono = "0.4"

[dev-dependencies]
proptest = "1.5"
tempfile = "3.14"

[profile.release]
lto = true
strip = true
codegen-units = 1
