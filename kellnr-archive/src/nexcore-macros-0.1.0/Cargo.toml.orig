[workspace]

[package]
name = "nexcore-macros"
version = "0.1.0"
edition = "2024"
rust-version = "1.85"
description = "Derive macros for NexVigilant Core primitive grounding and tier classification"
license = "MIT"
repository = "https://github.com/nexvigilant/nexcore"
keywords = ["nexcore", "derive", "macros", "primitives", "grounding"]
categories = ["development-tools::procedural-macro-helpers"]

[lib]
proc-macro = true

[dependencies]
syn = { version = "2.0.71", features = ["full"] }
quote = { version = "1.0.36" }
proc-macro2 = { version = "1.0.86" }
darling = { version = "0.20.10" }
nexcore-macros-core = { version = "1.0.0", path = "../nexcore-macros-core", registry = "nexcore" }
