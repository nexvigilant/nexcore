-- Boolean algebra theorems (new in v7)

theorem boolean_identity :
  "6 of 16 primitives ARE Boolean functions by definition (not mapping)",
  ∅  = FALSE       (val=0,  0000, "always nothing"),
  ×  = AND         (val=1,  0001, "both required"),
  κ  = XOR         (val=6,  0110, "what differs"),
  Σ  = OR          (val=7,  0111, "either suffices"),
  -> = IMPLICATION  (val=13, 1101, "if A then B"),
  ∃  = TRUE         (val=15, 1111, "always present")
  [proof: computational, theorem_07_boolean_identity — 6 identities verified + full truth table evaluation for all 4 input pairs, nexcore-lex-primitiva]

theorem core_irreversibility :
  "n-way AND of Pillars = n-way AND of Generators = ∝ (Irreversibility)",
  core(σ=14, κ=6, ς=3, ρ=11) = 1110 & 0110 & 0011 & 1011 = 0010 = 2 = ∝,
  core(σ=14, Σ=7, ρ=11, κ=6, ∃=15) = 0010 = 2 = ∝,
  "∝ is a fixed point: computation is thermodynamically irreversible",
  "Landauer 1961: erasing 1 bit dissipates >= kT * ln2 energy",
  contingent_on = boolean_identity,
  "result changes if any Pillar's Boolean value is reassigned"
  [proof: computational, theorem_08_core_irreversibility — exact bitwise AND of Pillars + Generators both = 2 = ∝, nexcore-lex-primitiva]

theorem pascal_distribution :
  "primitive count at each popcount of val = Pascal's row 4: 1, 4, 6, 4, 1",
  C(4,0) = 1 = |{∅}|,
  C(4,1) = 4 = |{×, ∝, ∂, ν}|,
  C(4,2) = 6 = |{ς, μ, κ, N, λ, π}|,
  C(4,3) = 4 = |{Σ, ρ, ->, σ}|,
  C(4,4) = 1 = |{∃}|,
  "sum = 16 = 2^4 = total primitives"
  [proof: computational, theorem_09_pascal_distribution — popcount of all 16 vals = [1,4,6,4,1] + per-primitive membership verified, nexcore-lex-primitiva]

theorem four_atoms :
  "IF the Boolean bijection holds, 4 primitives sit at bit positions {0,1,2,3}",
  × = 1 = 2^0,  -- AND at bit 0
  ∝ = 2 = 2^1,  -- INHIBIT at bit 1
  ∂ = 4 = 2^2,  -- CONV_INHIBIT at bit 2
  ν = 8 = 2^3,  -- NOR at bit 3
  "any primitive val = sum of atom vals, e.g. →(13) = ν(8) + ∂(4) + ×(1)",
  "the MATH is trivially true for any 4-bit system (binary representation)",
  "the ASSIGNMENT of which primitive sits at which bit is the non-trivial claim",
  contingent_on = boolean_identity
  [proof: computational, theorem_10_four_atoms — 4 power-of-2 vals + exhaustive bit decomposition of all 16 vals, nexcore-lex-primitiva]

theorem phase_transition :
  "max non-void core group = 8 (half of 16)",
  "8 PROCESS primitives (bit 1 set) share core = ∝",
  "8 STRUCTURE primitives (bit 1 clear) share core = ∅",
  "adding any 9th primitive from the other half -> core collapses to ∅",
  "this is a phase boundary: the largest tribe with shared truth = half"
  [proof: computational, theorem_11_phase_transition — 8/8 split, process core=∝, structure core=∅, 9th collapses, nexcore-lex-primitiva]

theorem conf_monotonicity :
  "conf(child) <= min(conf(parents)), conf never increases through derivation",
  "this is BY DESIGN (we chose min-propagation), not a physical law",
  "inspired by 2nd law / Landauer — analogy, not isomorphism",
  "alternatives exist: geometric mean, weighted average, product",
  "min was chosen for conservatism: never overestimate truth"
  [proof: computational, theorem_12_conf_monotonicity — 6 test cases verify min(parents) ≤ each parent + target sys=0.99, nexcore-lex-primitiva]


