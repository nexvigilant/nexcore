# Guardian MVP Environment Configuration
# Copy to /etc/guardian/guardian.env and fill in production values
# Permissions: sudo chmod 640 /etc/guardian/guardian.env
# Owner: sudo chown root:guardian /etc/guardian/guardian.env

# ────────────────────────────────────────────────────────────────────────────
# API Configuration
# ────────────────────────────────────────────────────────────────────────────
API_PORT=3030
API_KEY=                                   # Master API key (fallback, if needed)
RUST_LOG=info                              # Log level: debug, info, warn, error

# CORS & Trust
CORS_ORIGINS=https://studio.nexvigilant.com,https://nexvigilant.com,https://guardian.nexvigilant.com
TRUSTED_PROXIES=127.0.0.1,::1             # nginx reverse proxy

# Rate limiting (Guardian uses token bucket internally)
RATE_LIMIT_RPS=250                         # Requests per second (across all endpoints)
RATE_LIMIT_BURST=500                       # Burst allowance

# ────────────────────────────────────────────────────────────────────────────
# Stripe Billing Integration
# ────────────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_                 # Stripe secret key (test or live)
STRIPE_WEBHOOK_SECRET=whsec_               # Webhook signing secret from Stripe dashboard
STRIPE_PRODUCT_ID=prod_                    # Guardian product ID in Stripe

# Pricing tier IDs (from Stripe dashboard: Products → Guardian → Pricing → copy Price ID)
STRIPE_PRICE_RESEARCHER=price_             # $49/month researcher tier
STRIPE_PRICE_PROFESSIONAL=price_           # $199/month professional tier
STRIPE_PRICE_ENTERPRISE=price_             # $999/month enterprise tier (annual)

# ────────────────────────────────────────────────────────────────────────────
# Authentication (Firebase)
# ────────────────────────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=nexvigilant-digital-clubhouse
FIREBASE_API_KEY=AIzaSy                    # Firebase Web API key (from console)
GOOGLE_APPLICATION_CREDENTIALS=/etc/guardian/firebase-credentials.json

# ────────────────────────────────────────────────────────────────────────────
# Database & Storage
# ────────────────────────────────────────────────────────────────────────────
GUARDIAN_DB_PATH=/var/lib/guardian/guardian.db
GUARDIAN_DB_MAX_CONNS=32                   # SQLite write-ahead log supports concurrent reads
DATABASE_URL=sqlite:///var/lib/guardian/guardian.db

# Audit & Archival
AUDIT_BUFFER_SIZE=10000                    # Queue size before flush to disk
AUDIT_FLUSH_INTERVAL_SECS=60               # Flush audit buffer every 60s
AUDIT_SECRET=                              # HMAC key for audit trail integrity (32+ bytes, base64)
AUDIT_ENABLE_COMPRESSION=true              # gzip audit logs for storage efficiency

# ────────────────────────────────────────────────────────────────────────────
# Application & Deployment
# ────────────────────────────────────────────────────────────────────────────
APP_BASE_URL=https://guardian.nexvigilant.com
APP_ENV=production                         # production, staging, development
APP_NAME=Guardian API
APP_VERSION=0.1.0-mvp

# Health check metadata (returned from /health endpoint)
DEPLOYMENT_ID=                             # Unique deployment identifier (uuid or git hash)
BUILD_TIMESTAMP=                           # ISO8601 build timestamp

# ────────────────────────────────────────────────────────────────────────────
# Security & Secrets
# ────────────────────────────────────────────────────────────────────────────

# JWT Signing (if using JWT for API tokens instead of Firebase)
JWT_SECRET=                                # 32+ bytes, base64-encoded
JWT_EXPIRY_HOURS=24

# Session Management
SESSION_TIMEOUT_SECS=3600                  # 1 hour
SESSION_COOKIE_SECURE=true                 # HTTPS only
SESSION_COOKIE_HTTPONLY=true               # No JavaScript access
SESSION_COOKIE_SAMESITE=Strict             # CSRF protection

# ────────────────────────────────────────────────────────────────────────────
# Observability & Monitoring
# ────────────────────────────────────────────────────────────────────────────

# Metrics (Prometheus, if enabled)
METRICS_ENABLED=true
METRICS_PORT=9090                          # Not exposed externally, only localhost

# Error tracking (Sentry, if enabled)
SENTRY_DSN=                                # https://sentry.io/settings/organizations/.../projects/.../keys/
SENTRY_ENVIRONMENT=production
SENTRY_TRACE_SAMPLE_RATE=0.1               # Sample 10% of traces

# ────────────────────────────────────────────────────────────────────────────
# Email & Notifications
# ────────────────────────────────────────────────────────────────────────────
MAIL_ENABLED=true
MAIL_PROVIDER=sendgrid                     # sendgrid, ses, smtp
MAIL_FROM=noreply@nexvigilant.com
SENDGRID_API_KEY=SG.                       # SendGrid API key

# Alert emails (comma-separated)
ALERT_EMAIL_BILLING=billing@nexvigilant.com
ALERT_EMAIL_SECURITY=security@nexvigilant.com
ALERT_EMAIL_OPS=ops@nexvigilant.com

# ────────────────────────────────────────────────────────────────────────────
# Feature Flags
# ────────────────────────────────────────────────────────────────────────────
FEATURE_GUARDIAN_BILLING=true               # Enable Stripe integration
FEATURE_GUARDIAN_AUDIT=true                 # Enable audit logging
FEATURE_GUARDIAN_MFA=false                  # Multi-factor authentication (future)
FEATURE_GUARDIAN_API_KEYS=true              # Long-lived API keys for service accounts

# ────────────────────────────────────────────────────────────────────────────
# Deployment & Rollout
# ────────────────────────────────────────────────────────────────────────────

# Blue-green deployment metadata
DEPLOYMENT_SLOT=blue                       # blue or green (used for traffic switching)
DEPLOYMENT_REPLICAS=1                      # Number of replicas (for future K8s migration)

# Canary/progressive rollout (future)
TRAFFIC_CANARY_PCT=0                       # 0 = no canary, 100 = full canary

# ────────────────────────────────────────────────────────────────────────────
# Backup & Disaster Recovery
# ────────────────────────────────────────────────────────────────────────────
BACKUP_ENABLED=true
BACKUP_PATH=/var/lib/guardian/backups
BACKUP_RETENTION_DAYS=30
BACKUP_GCS_BUCKET=nexvigilant-guardian-backups

# ────────────────────────────────────────────────────────────────────────────
# Advanced: Performance Tuning
# ────────────────────────────────────────────────────────────────────────────
HTTP_TIMEOUT_SECS=30                       # External API call timeout
DB_QUERY_TIMEOUT_SECS=5                    # SQLite query timeout
MAX_REQUEST_SIZE_BYTES=1048576             # 1MB max request body
WORKER_THREADS=4                           # tokio worker thread count (auto if unset)

# ────────────────────────────────────────────────────────────────────────────
# Notes for Deployment
# ────────────────────────────────────────────────────────────────────────────
# 1. Generate secrets (AUDIT_SECRET, JWT_SECRET, etc.):
#    openssl rand -base64 32
#
# 2. Store Firebase credentials at /etc/guardian/firebase-credentials.json:
#    - Download from Firebase Console → Project Settings → Service Accounts
#    - Restrict to root:guardian, mode 640
#
# 3. Stripe keys/secrets:
#    - Test keys from Stripe Dashboard → Developers → API keys
#    - NEVER commit production keys to git
#    - Rotate regularly per Stripe security recommendations
#
# 4. Deploy to GCE instance:
#    ./guardian-deploy.sh
#    (builds locally, uploads to kellnr-registry, restarts systemd service)
#
# 5. Verify deployment:
#    curl https://guardian.nexvigilant.com/health
#    journalctl -u guardian-api -f
#
# 6. Monitor:
#    systemctl status guardian-api
#    journalctl -u guardian-monitor.timer -f
