[workspace]

[package]
name = "nexcore-algovigilance"
version = "1.0.0"
edition = "2024"
authors = ["NexVigilant Team <team@nexvigilant.com>"]
license = "LicenseRef-Proprietary"
repository = "https://github.com/nexvigilant/nexcore"
rust-version = "1.85"
description = "Algorithmic vigilance: ICSR deduplication, signal triage with decay, and federated persistence"
keywords = ["pharmacovigilance", "deduplication", "signal-detection", "triage", "decay"]
categories = ["algorithms", "science"]

[dependencies]
# NexCore internal
nexcore-dtree = { version = "1.0.0", path = "../nexcore-dtree", registry = "nexcore" }
nexcore-lex-primitiva = { version = "0.1.0", path = "../nexcore-lex-primitiva", registry = "nexcore" }

# Serialization
serde = { version = "1.0.204", features = ["derive"] }
serde_json = { version = "1.0.120" }

# Error handling
thiserror = { version = "1.0.61" }

# Date/time and IDs
chrono = { version = "0.4.38", features = ["serde"] }

# Parallelism
rayon = { version = "1.10.0" }

# Home directory
dirs = { version = "5.0.1" }

[dev-dependencies]
tempfile = { version = "3.10.1" }
tokio = { version = "1.38.0", features = ["full"] }

[lints.rust]
async_fn_in_trait = "allow"
dead_code = "allow"
unused_imports = "allow"
unused_variables = "allow"
unused_mut = "allow"
unused_assignments = "allow"
unused_must_use = "allow"

[lints.clippy]
all = "allow"
pedantic = "allow"
nursery = "allow"
cargo = "allow"
map_unwrap_or = "allow"
manual_map = "allow"
option_map_or_none = "allow"
derivable_impls = "allow"
unwrap_used = "allow"
expect_used = "allow"
panic = "allow"
todo = "allow"
unimplemented = "allow"
unreachable = "allow"
