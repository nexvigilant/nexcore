[workspace]

[package]
name = "nexcore-control-center"
version = "0.1.0"
edition = "2021"
description = "NexVigilant Core unified monitoring dashboard - 100% Rust with Ferrostack"

# Standalone - not part of NexCore workspace (different Leptos deps)

[lib]
crate-type = ["cdylib", "rlib"]

[[bin]]
name = "nexcore-control-center"
path = "src/main.rs"

[dependencies]
leptos = { version = "0.7" }
leptos_router = { version = "0.7" }
leptos_meta = { version = "0.7" }
leptos_axum = { version = "0.7", optional = true }

axum = { version = "0.7", optional = true }
tokio = { version = "1", features = ["full"], optional = true }
tower-http = { version = "0.6", features = ["fs", "cors"], optional = true }

# HTTP client for API calls
reqwest = { version = "0.12", features = ["json"], optional = true }

# Serialization
serde = { version = "1", features = ["derive"] }
serde_json = "1"

# Time
chrono = { version = "0.4", features = ["serde"] }

# Error handling
anyhow = "1"

[features]
default = []
ssr = [
    "leptos/ssr",
    "leptos_router/ssr",
    "leptos_meta/ssr",
    "dep:leptos_axum",
    "dep:axum",
    "dep:tokio",
    "dep:tower-http",
    "dep:reqwest",
]
hydrate = [
    "leptos/hydrate",
]

[package.metadata.leptos]
output-name = "nexcore-control-center"
bin-target = "nexcore-control-center"
site-root = "target/site"
site-pkg-dir = "pkg"
site-addr = "127.0.0.1:3000"
reload-port = 3001
browser-open = false
